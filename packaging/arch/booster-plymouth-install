#!/bin/bash -e
# Builds booster-plymouth initramfs images alongside the standard booster images.
# Triggered by the same events as 90-booster-install.hook, plus plymouth package updates.

config="/etc/booster-plymouth.yaml"
generator="/home/stew/Coding/claude/booster/generator/generator"
init_binary="/home/stew/Coding/claude/booster/init/init"

if [[ ! -f "${config}" ]]; then
  echo ">>> [booster-plymouth] No ${config} found, skipping" >&2
  exit 0
fi

if [[ ! -f "${generator}" ]]; then
  echo ">>> [booster-plymouth] No ${generator} found, skipping" >&2
  exit 0
fi

if [[ ! -f "${init_binary}" ]]; then
  echo ">>> [booster-plymouth] No ${init_binary} found, skipping" >&2
  exit 0
fi

kernels=()
all=0

while read -r line; do
  if [[ ${line} != usr/lib/modules/* ]]; then
    # triggers on booster binary, booster lib, or plymouth package change
    all=1
    break
  fi

  kernels+=("/${line%/vmlinuz}")
done

if (( all )); then
  mapfile -d '' kernels < <(find /usr/lib/modules -maxdepth 1 -type d ! -name "modules" -print0)
fi

for kernel in "${kernels[@]}"; do
  if ! pacman -Qqo "${kernel}/pkgbase" > /dev/null 2>&1; then
    continue
  fi
  read -r pkgbase < "${kernel}/pkgbase"

  echo ">>> [booster-plymouth] Building image for ${pkgbase}"
  "${generator}" build --force --config "${config}" --init-binary "${init_binary}" --kernel-version "${kernel##/usr/lib/modules/}" "/boot/booster-plymouth-${pkgbase}.img" &
done

wait
